# 飞书多维表格配置
# 请在 Netlify 项目设置 → Environment Variables 中配置以下变量

# 1. 在飞书开放平台创建自建应用，获取以下两个值
FEISHU_APP_ID=cli_xxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# 2. 多维表格的 URL 格式: https://[xxx].feishu.cn/base/[app_token]?table=[table_id]
FEISHU_APP_TOKEN=bascnxxxxxxxxxxxxxxxxxxxxx
FEISHU_TABLE_ID=tblxxxxxxxxxxxxxx
